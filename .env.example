# Database (Docker Compose)
DATABASE_URL=postgres://realorfake:realorfake_dev_pwd@localhost:5432/realorfake

# Redis (Docker Compose)
REDIS_URL=redis://localhost:6379

# Gemini AI — get from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot — get from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# JWT Secrets — generate strong random strings for production
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-in-production

# Server
PORT=3001
NODE_ENV=development

# App
APP_URL=http://localhost:3000
